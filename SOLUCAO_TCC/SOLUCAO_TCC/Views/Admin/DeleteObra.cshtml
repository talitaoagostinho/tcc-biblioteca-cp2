@model SOLUCAO_TCC.Models.Obra

<div class="modal-dialog">
    <div class="modal-content">
        <div class="modal-header">
            <h1 class="modal-title fs-5">Certeza que deseja deletar esta Obra?</h1>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>

        <div>

            <dl class="dl-horizontal">



                <dt>
                    @Html.DisplayNameFor(model => model.Nome)
                </dt>

                <dd>
                    @Html.DisplayFor(model => model.Nome)
                </dd>

                <dt>
                    @Html.DisplayNameFor(model => model.Autor)
                </dt>

                <dd>
                    @Html.DisplayFor(model => model.Autor)
                </dd>

                <dt>
                    @Html.DisplayNameFor(model => model.Genero)
                </dt>

                <dd>
                    @Html.DisplayFor(model => model.Genero)
                </dd>

                <dt>
                    @Html.DisplayNameFor(model => model.Quantidade)
                </dt>

                <dd>
                    @Html.DisplayFor(model => model.Quantidade)
                </dd>

                <dt>
                    @Html.DisplayNameFor(model => model.Localizacao)
                </dt>

                <dd>
                    @Html.DisplayFor(model => model.Localizacao)
                </dd>

                <dt>
                    @Html.DisplayNameFor(model => model.Pdf)
                </dt>

                <dd>
                    @if (Model.Pdf == true)
                    {
                        <small>True</small>
                    }
                    else
                    {
                        <small>False</small>
                    }
                </dd>

                <dt>
                    @Html.DisplayNameFor(model => model.Tipo)
                </dt>

                <dd>
                    @Html.DisplayFor(model => model.Tipo)
                </dd>



            </dl>

            @using (Html.BeginForm("Delete", "Admin", FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                @Html.HiddenFor(model => model.Cod_Obra)
                @Html.HiddenFor(model => model.Detalhes)
                @Html.HiddenFor(model => model.Imagem)
                @Html.HiddenFor(model => model.Pdf_Link)

        <div class="form-actions no-color">
            <button class="btn btn-danger"><i class="bi bi-trash-fill"></i> Delete</button>
        </div>
            }
            <br />
        </div>
    </div>
</div>

