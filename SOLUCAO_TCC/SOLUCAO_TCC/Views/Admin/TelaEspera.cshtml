<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body style="background-color: #E0dddd ">
    <nav class="navbar fixed-top border border-secondary border-3" style="background-color: #2b7ead">
        <div class="container-md">
            <a class="navbar-brand">
                <img src="~/Content/imgfixa/cp2logo.png" alt="Logo" width="200" height="130" class="d-inline-block align-text-top">
            </a>
            <span class="navbar-text fs-1 p-3 bg-info bg-opacity-10 border border-info rounded-end rounded-start" style="font-family:fantasy">BIBLIOTECA DO COLÉGIO PEDRO II - EN II</span>
            <button class="navbar-toggler border border-info bg-opacity-10" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasDarkNavbar" aria-controls="offcanvasDarkNavbar" style="height: 100px; width: 100px">
                <span class="navbar-toggler-icon" style="height: 80px; width: 80px"></span>
            </button>
            <div class="offcanvas offcanvas-end text-bg-dark" tabindex="-1" id="offcanvasDarkNavbar" aria-labelledby="offcanvasDarkNavbarLabel">
                <div class="offcanvas-header">
                    <h5 class="offcanvas-title" id="offcanvasDarkNavbarLabel">Conta de Usuário</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
                </div>
                <div class="offcanvas-body">
                    <ul class="navbar-nav justify-content-end flex-grow-1 pe-3">

                        <li class="nav-item ">
                            @if (Request.IsAuthenticated)
                            {
                                using (Html.BeginForm("LogOff", "Account", FormMethod.Post, new { id = "logoutForm", @class = "navbar-right" }))
                                {
                                    @Html.AntiForgeryToken()
                                <li class="nav-item d-grid gap-2">
                                    <a class="btn btn-danger" href="javascript:document.getElementById('logoutForm').submit()">Fazer Logout <i class="bi bi-box-arrow-left"></i></a>
                                </li>
                            }
                        }
                        else
                        {

                        }

                        </ul>
                    </div>
                </div>
            </div>
        </nav>
    </body>
</html>
<br />
<br />
<br />
<br />
<br />


<div class="row">
    <div class="col-3">
    </div>
    <div class="col-6">
        <div id="carouselExampleCaptions" class="carousel slide border border-dark rounded-end rounded-start border-3" data-bs-ride="false" style="max-height:100%">
            <div class="carousel-indicators">
                <button type="button" data-bs-target="#carouselExampleCaptions" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
                <button type="button" data-bs-target="#carouselExampleCaptions" data-bs-slide-to="1" aria-label="Slide 2"></button>
                <button type="button" data-bs-target="#carouselExampleCaptions" data-bs-slide-to="2" aria-label="Slide 3"></button>
            </div>
            <div class="carousel-inner">
                <div class="carousel-item active">
                    <img src="~/Content/imgfixa/biblio1.jpg" class="d-block w-100" alt="...">
                    <div class="carousel-caption d-none d-md-block">
                        <h3 class="fw-bolder   bg-primary bg-opacity-50 border border-dark rounded-end rounded-start" style="color: lightgoldenrodyellow ">Seu Cadastro Foi Finalizado</h3>
                        <p class="fw-bolder   bg-primary bg-opacity-50 border border-dark rounded-end rounded-start" style="color: lightgoldenrodyellow ">Enquanto aguarda a aprovação do seu cadastro, você pode descobrir algumas curiosidades da nossa biblioteca!</p>
                    </div>
                </div>
                <div class="carousel-item">
                    <img src="~/Content/imgfixa/biblio2.jpg" class="d-block w-100" alt="...">
                    <div class="carousel-caption d-none d-md-block">
                        <h3 class="fw-bolder   bg-primary bg-opacity-50 border border-dark rounded-end rounded-start" style="color: lightgoldenrodyellow ">Bilbioteca Hélio Fontes</h3>
                        <p class="fw-bolder   bg-primary bg-opacity-50 border border-dark rounded-end rounded-start" style="color: lightgoldenrodyellow ">Temos diversos tipos de obras, como livros acadêmicos, infantis, quadrinhos, literatura popular brasileira e crônicas.</p>
                    </div>
                </div>
                <div class="carousel-item">
                    <img src="~/Content/imgfixa/biblio3.jpg" class="d-block w-100" alt="...">
                    <div class="carousel-caption d-none d-md-block">
                        <h3 class="fw-bolder   bg-primary bg-opacity-50 border border-dark rounded-end rounded-start" style="color: lightgoldenrodyellow ">Eventos e Palestras</h3>
                        <p class="fw-bolder   bg-primary bg-opacity-50 border border-dark rounded-end rounded-start" style="color: lightgoldenrodyellow ">O espaço da biblioteca também é utilizado para eventos e palestras para estudantes, funcionários e responsáveis.</p>
                    </div>
                </div>
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleCaptions" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Previous</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleCaptions" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Next</span>
            </button>
        </div>
    </div>
</div>
<div class="col-3"> </div>
